# URL do banco SQLite (local)
DATABASE_URL="file:./prisma/dev.db"

# Chave secreta para JWT (use uma string longa e aleatória em produção)
JWT_SECRET="sua_chave_secreta_aqui"

# URL do frontend (para CORS). Em produção: https://carbon-defuse-frontend.onrender.com
FRONTEND_URL="http://localhost:5173"

# Porta do servidor (o Render define automaticamente)
PORT=3000
